# LLM provider: openai | gemini
LLM_PROVIDER=openai
LLM_FALLBACK_ENABLED=true
PROMPT_VERSION=v1

# OpenAI (set one provider)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (alternative / fallback)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Storage (Phase 5)
# auto = Supabase when SUPABASE_URL+SUPABASE_KEY set, else JSON
STORAGE_BACKEND=auto
SUPABASE_URL=
SUPABASE_KEY=

# App / security
# Admin password is enforced only when APP_ENV=production
APP_ENV=development
ADMIN_PASSWORD=
WEBHOOK_TOKEN=
WEBHOOK_PORT=8080

# Email / SMTP (Phase 3 — optional; dry-run logs to console if unset)
ADMIN_EMAIL=admin@nayepankh.org
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY_SECONDS=1.0

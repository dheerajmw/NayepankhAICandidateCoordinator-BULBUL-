{
  "name": "Bulbul by NayePankh Foundation — Production Reminder Webhook",
  "description": "n8n workflow calling the Phase 5 webhook server.",
  "nodes": [
    {
      "id": "cron_trigger",
      "name": "Daily 9 AM",
      "type": "n8n-nodes-base.cron",
      "parameters": {
        "triggerTimes": {
          "item": [{ "hour": 9, "minute": 0 }]
        }
      }
    },
    {
      "id": "webhook_request",
      "name": "POST Reminder Webhook",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "method": "POST",
        "url": "https://your-webhook-host/webhooks/reminders",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Webhook-Token",
              "value": "={{$env.WEBHOOK_TOKEN}}"
            }
          ]
        },
        "options": {}
      },
      "notes": "Replace URL with your Render/webhook deployment URL."
    },
    {
      "id": "execute_fallback",
      "name": "Fallback: Run Script",
      "type": "n8n-nodes-base.executeCommand",
      "disabled": true,
      "parameters": {
        "command": "cd /path/to/naye-pankh-bulbul && .venv/bin/python scripts/run_reminders.py"
      },
      "notes": "Use if webhook server is unavailable."
    }
  ],
  "connections": {
    "Daily 9 AM": {
      "main": [[{ "node": "POST Reminder Webhook", "type": "main", "index": 0 }]]
    }
  },
  "meta": {
    "project": "Bulbul by NayePankh Foundation",
    "phase": 5
  }
}
